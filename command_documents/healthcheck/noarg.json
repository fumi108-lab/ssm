{
  "schemaVersion": "2.2",
  "description": "Script to check process health",
  "mainSteps": [
    {
      "action": "aws:runShellScript",
      "name": "checkService",
      "inputs": {
        "runCommand": [
          "#!/bin/bash",
          "echo ver2",
          "",
          "SUMMARY=\"\"",
          "",
          "# 1) sshdサービス確認 / Check sshd service",
          "echo \"1. sshdサービス確認 / Check sshd service\"",
          "echo \"systemctl is-active sshd\"",
          "STATUS=$(systemctl is-active sshd)",
          "echo \"$STATUS\"",
          "if [ \"$STATUS\" = \"active\" ]; then",
          "SUMMARY=\"OK\"",
          "else",
          "SUMMARY=\"NG オフライン時間帯の影響も考慮に入れること / Please consider the impact of offline hours\"",
          "fi",
          "echo \"\"",
          "",
          "# 2) sshdサービスステータス出力 / Show sshd service status",
          "echo \"2. sshdサービスステータス出力 / Show sshd service status\"",
          "echo \"systemctl status sshd  --no-pager | head -20\"",
          "systemctl status sshd | head -20",
          "echo \"\"",
          "",
          "# 3) sshdプロセス確認 / Check sshd process",
          "echo \"3. sshdプロセス確認 / Check sshd process\"",
          "echo \"ps -ef | grep sshd | grep -v grep\"",
          "ps -ef | grep sshd | grep -v grep",
          "echo \"\"",
          "",
          "# サマリ表示 / Display Summary",
          "echo \"サマリ表示 / Display Summary\"",
          "echo \"sshd Service: $SUMMARY\"",
          "echo \"\""
        ]
      }
    }
  ]
}
